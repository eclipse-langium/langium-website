{
  "name": "langium-website-core",
  "version": "1.0.0",
  "type": "module",
  "description": "Monaco editor utilities for the Langium website",
  "author": "TypeFox",
  "license": "MIT",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
  },
  "typesVersions": {
    "*": {
      ".": [
        "dist/index"
      ]
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist",
    "compile": "tsc",
    "build": "npm run clean && npm run compile"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "monaco-editor": "~0.55.1",
    "monaco-editor-workers": "~0.55.1",
    "monaco-languageclient": "~10.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vscode-languageserver": "~9.0.1"
  },
  "volta": {
    "node": "20.18.1",
    "npm": "10.9.0"
  }
}
